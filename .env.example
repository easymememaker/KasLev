# -----------------------------------------------------------------------------
# KasLev app server — copy to `.env` (gitignored) and fill in what you need.
# The oracle-keeper signing key lives in contracts/.env, NOT here.
# -----------------------------------------------------------------------------

# Optional: Gemini API key for the AI strategies tab. Without it the server
# answers with a local, honestly-labeled quant heuristic instead.
GEMINI_API_KEY=""

# Server port (default 3000).
PORT="3000"

# Set to "true" to turn the built-in oracle keeper off (e.g. when a standalone
# keeper process handles price pushes instead).
KEEPER_DISABLED="false"

# Keeper push cadence in milliseconds. Default 150000 (2.5 min) — half of the
# oracle's 300s freshness window, so one failed push still has a retry.
KEEPER_INTERVAL_MS="150000"
