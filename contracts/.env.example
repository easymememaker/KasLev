# -----------------------------------------------------------------------------
# KasLev contracts — deployment environment.
# Copy this file to `.env` (which is gitignored) and fill in real values.
# NEVER commit `.env`. NEVER paste your seed phrase or main-wallet key anywhere.
# Use a FRESH, dedicated deployer wallet — not your personal savings wallet.
# -----------------------------------------------------------------------------

# Kasplex zkEVM testnet RPC (default already set in hardhat.config.js).
KASPA_L2_RPC_URL="https://rpc.kasplextest.xyz"

# Private key of the DEPLOYER wallet, WITHOUT the 0x prefix is also fine.
# This wallet must hold some testnet KAS for gas (+ the seed if DEPOSIT_SEED=true).
DEPLOYER_PRIVATE_KEY=""

# --- Protocol parameters (all optional; sensible defaults in deploy.js) ---
# Address that receives developer trading fees (defaults to deployer).
DEV_FEE_WALLET=""
# Address that funds & may later reclaim the seed principal (defaults to deployer).
DEVELOPER_WALLET=""
# Initial locked liquidity in whole KAS. Spec = 30000.
SEED_KAS="30000"
# Seed lock duration in days. Spec = 100.
LOCK_DAYS="100"
# Set to "true" to deposit the seed during deployment.
DEPOSIT_SEED="false"
